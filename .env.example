# SAP Web GUI URL (required for integration tests)
SAP_URL=https://your-sap-server/sap/bc/gui/sap/its/webgui

# SAP credentials (for automated integration tests)
SAP_USER=your-username
SAP_PASSWORD=your-password
SAP_MANDANT=100
SAP_LANGUAGE=DE

# Browser configuration (optional)
# Default is connect mode: expects Chrome running with --remote-debugging-port=9222
# CDP_URL=http://localhost:9222
# Uncomment to use Playwright-managed browser instead (requires `playwright install`):
# BROWSER_MODE=launch
# BROWSER_HEADLESS=false

# GitHub integration
# GITHUB_USER and GITHUB_PAT are used for abapGit authentication (pull/push)
# GITHUB_PAT is also used for feedback/issue creation if GITHUB_REPO is set
# Generate token at: https://github.com/settings/tokens
GITHUB_USER=your-github-username
GITHUB_PAT=ghp_your_token_here
# GITHUB_REPO=Hochfrequenz/sapwebgui.mcp

# abapGit-specific PAT (optional, overrides GITHUB_PAT for abapGit operations)
# Use this if you need a separate token for abapGit vs feedback
# ABAPGIT_PAT=ghp_your_abapgit_token_here

# Papertrail logging (optional)
# PAPERTRAIL_HOST=logs5.papertrailapp.com
# PAPERTRAIL_PORT=35329

# Audit logging (optional)
# AUDIT_LOG_DIR=/path/to/audit/logs
