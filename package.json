{
  "name": "sapwebguimcp",
  "private": true,
  "description": "JavaScript and Markdown formatting for SAP Web GUI MCP Server",
  "devDependencies": {
    "prettier": "3.8.3"
  },
  "scripts": {
    "format": "prettier --write src/**/*.js **/*.md",
    "format:check": "prettier --check src/**/*.js **/*.md"
  }
}
